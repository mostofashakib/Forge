from __future__ import annotations
from pathlib import Path
from forge.customization.config import load_config
from forge.runtime.reward import RewardBreakdown, RewardComponent

# Generated by Forge — override in custom/rewards.py
# @reward("{{ task.name }}")


def compute_{{ task.name }}_reward(
    state: dict,
    trajectory,
    verifier_results: list,
    task: dict | None = None,
) -> RewardBreakdown:
    cfg = load_config(Path(__file__).parent.parent)

    avg_score = (
        sum(vr.score for vr in verifier_results) / len(verifier_results)
        if verifier_results else 0.0
    )
    task_success_reward = avg_score * cfg.reward.base_success

    policy_violations = sum(
        1 for e in trajectory.events if e.get("type") == "policy_violation"
    )
    policy_compliance_reward = -cfg.reward.policy_violation_penalty * policy_violations

    semantic_score = 0.0
    for vr in verifier_results:
        for check in vr.checks:
            if check.name.startswith("semantic:"):
                semantic_score = check.score
                break
    semantic_quality_reward = semantic_score * cfg.reward.semantic_weight

    action_cost = cfg.reward.step_penalty * trajectory.step_count

    invalid_count = (task or {}).get("invalid_action_count", 0)
    invalid_action_penalty = cfg.reward.invalid_action_penalty * invalid_count

    total = (
        task_success_reward
        + policy_compliance_reward
        + semantic_quality_reward
        - action_cost
        - invalid_action_penalty
    )
    total = max(cfg.reward.min_reward, min(cfg.reward.max_reward, total))

    return RewardBreakdown(
        total_reward=total,
        components=[
            RewardComponent(name="task_success_reward", value=task_success_reward),
            RewardComponent(name="policy_compliance_reward", value=policy_compliance_reward),
            RewardComponent(name="semantic_quality_reward", value=semantic_quality_reward),
            RewardComponent(name="action_cost", value=-action_cost),
            RewardComponent(name="invalid_action_penalty", value=-invalid_action_penalty),
        ],
    )
