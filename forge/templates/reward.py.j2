from __future__ import annotations
from forge.runtime.reward import RewardBreakdown, RewardComponent

# Generated by Forge — override in custom/rewards.py
# @reward("{{ task.name }}_reward")


def compute_{{ task.name }}_reward(
    state: dict,
    trajectory,
    verifier_results: list,
    task: dict | None = None,
) -> RewardBreakdown:
    pass_rate = (
        sum(vr.score for vr in verifier_results) / len(verifier_results)
        if verifier_results else 0.0
    )
    step_penalty = 0.01 * trajectory.step_count
    total = max(-1.0, min(1.0, pass_rate - step_penalty))

    return RewardBreakdown(
        total_reward=total,
        components=[
            RewardComponent(name="task_success", value=pass_rate),
            RewardComponent(name="step_efficiency", value=-step_penalty),
        ],
    )
