# Copy this file to .env.local and fill in values for your environment.

# Base URL for the Forge backend API.
# Defaults to http://localhost:8000 in development.
# Required in production.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical URL of this frontend deployment (used for SEO metadata).
# Required in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
